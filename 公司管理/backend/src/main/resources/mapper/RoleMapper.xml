<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.companymanagement.mapper.RoleMapper">
    <select id="selectByCompanyId" resultType="com.example.companymanagement.entity.Role">
        SELECT * FROM role WHERE company_id = #{companyId} ORDER BY name
    </select>
    
    <select id="selectByCode" resultType="com.example.companymanagement.entity.Role">
        SELECT * FROM role WHERE code = #{code}
    </select>
</mapper>