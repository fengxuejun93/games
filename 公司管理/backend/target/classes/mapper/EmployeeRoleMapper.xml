<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.companymanagement.mapper.EmployeeRoleMapper">
    <insert id="insertBatch">
        INSERT INTO employee_role (employee_id, role_id) VALUES
        <foreach collection="roleIds" item="roleId" separator=",">
            (#{employeeId}, #{roleId})
        </foreach>
    </insert>
    
    <delete id="deleteByEmployeeId">
        DELETE FROM employee_role WHERE employee_id = #{employeeId}
    </delete>
    
    <select id="selectRolesByEmployeeId" resultType="com.example.companymanagement.entity.Role">
        SELECT r.* FROM role r
        JOIN employee_role er ON r.id = er.role_id
        WHERE er.employee_id = #{employeeId}
    </select>
    
    <select id="selectRoleIdsByEmployeeId" resultType="java.lang.Long">
        SELECT role_id FROM employee_role WHERE employee_id = #{employeeId}
    </select>
</mapper>