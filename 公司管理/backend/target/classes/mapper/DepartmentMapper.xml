<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.companymanagement.mapper.DepartmentMapper">
    <select id="selectByCompanyId" resultType="com.example.companymanagement.entity.Department">
        SELECT * FROM department WHERE company_id = #{companyId} ORDER BY parent_id, name
    </select>
</mapper>